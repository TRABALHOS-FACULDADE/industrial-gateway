      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "1": { "text": "Conectado", "color": "green", "index": 0 } } }], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } }, "overrides": [] },
