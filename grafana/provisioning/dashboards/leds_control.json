      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }, { "color": "green", "value": 1 }] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgres-industrial" }, "format": "table", "rawQuery": true, "rawSql": "SELECT COUNT(*) AS \"confirmados\" FROM led_events WHERE confirmed_by_plc = TRUE AND occurred_at >= NOW() - INTERVAL '15 minutes'", "refId": "A" }]
    },

    {
      "id": 21,
      "type": "stat",
      "title": "Falhas Recentes",
      "gridPos": { "h": 3, "w": 6, "x": 15, "y": 8 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgres-industrial" },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] },
      "targets": [{ "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgres-industrial" }, "format": "table", "rawQuery": true, "rawSql": "SELECT COUNT(*) AS \"falhas\" FROM led_events WHERE error IS NOT NULL AND occurred_at >= NOW() - INTERVAL '15 minutes'", "refId": "A" }]
    },

    {
      "id": 22,
      "type": "timeseries",
      "title": "Eventos por Minuto",
      "gridPos": { "h": 8, "w": 18, "x": 3, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgres-industrial" },
      "options": { "tooltip": { "mode": "single", "sort": "none" }, "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom", "calcs": [] } },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "lineInterpolation": "linear", "barAlignment": 0, "lineWidth": 1, "fillOpacity": 45, "gradientMode": "none", "spanNulls": false, "insertNulls": false, "showPoints": "never", "pointSize": 5, "stacking": { "mode": "normal", "group": "A" }, "axisPlacement": "auto", "axisLabel": "", "axisColorMode": "text", "axisBorderShow": false, "scaleDistribution": { "type": "linear" }, "axisCenteredZero": false, "hideFrom": { "tooltip": false, "viz": false, "legend": false }, "thresholdsStyle": { "mode": "off" } }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [
        { "matcher": { "id": "byName", "options": "Confirmados" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
        { "matcher": { "id": "byName", "options": "Falhas" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
      ] },
      "targets": [
        { "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgres-industrial" }, "format": "time_series", "rawQuery": true, "rawSql": "SELECT date_trunc('minute', occurred_at) AS \"time\", COUNT(*) FILTER (WHERE confirmed_by_plc = TRUE AND error IS NULL) AS \"Confirmados\", COUNT(*) FILTER (WHERE error IS NOT NULL) AS \"Falhas\" FROM led_events WHERE occurred_at >= $__timeFrom() AND occurred_at <= $__timeTo() GROUP BY 1 ORDER BY 1", "refId": "A" }
      ]
    },

    {
      "id": 1,
      "type": "table",
      "title": "Estado dos LEDs",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 11 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgres-industrial" },
      "options": { "cellHeight": "sm", "showHeader": true, "footer": { "show": false } },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "custom": { "align": "center" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Estado" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              { "id": "mappings", "value": [{ "type": "value", "options": {
                "ON":  { "color": "green", "index": 0, "text": "ON"  },
                "OFF": { "color": "red",   "index": 1, "text": "OFF" }
              }}]}
            ]
          }
        ]
      },
      "targets": [{ "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgres-industrial" }, "format": "table", "rawQuery": true, "rawSql": "SELECT l.id AS \"LED\", CASE WHEN l.toggled THEN 'ON' ELSE 'OFF' END AS \"Estado\", COALESCE(CASE WHEN e.error IS NOT NULL THEN 'Falha' WHEN e.confirmed_by_plc THEN 'Confirmado' ELSE 'Nao confirmado' END, 'Sem evento') AS \"Ultima confirmacao\", l.updated_at AS \"Atualizado em\" FROM leds l LEFT JOIN LATERAL (SELECT confirmed_by_plc, error FROM led_events WHERE led_id = l.id ORDER BY occurred_at DESC LIMIT 1) e ON TRUE ORDER BY l.id", "refId": "A" }]
    },

