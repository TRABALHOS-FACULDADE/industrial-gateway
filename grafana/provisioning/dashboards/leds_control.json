      "targets": [{ "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgres-industrial" }, "format": "table", "rawQuery": true, "rawSql": "SELECT occurred_at AS \"Data/Hora\", led_id AS \"LED\", CASE WHEN toggled THEN 'ON' ELSE 'OFF' END AS \"Estado\", CASE WHEN error IS NOT NULL THEN 'Falha' WHEN confirmed_by_plc THEN 'Confirmado' ELSE 'Nao confirmado' END AS \"Confirmacao\", COALESCE(error, 'Sem erro') AS \"Erro\" FROM led_events ORDER BY occurred_at DESC LIMIT 50", "refId": "A" }]
